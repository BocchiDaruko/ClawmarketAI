# ─────────────────────────────────────────────────────────────────────────────
#  ClawmarketAI — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployer wallet ───────────────────────────────────────────────────────────
# Private key of the wallet that will deploy the contracts.
# Must have ETH on Base mainnet for gas fees.
DEPLOYER_PRIVATE_KEY=0xyour_private_key_here

# ── RPC endpoints ─────────────────────────────────────────────────────────────
# Base Mainnet — get a free key at https://dashboard.alchemy.com or https://infura.io
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Base Sepolia Testnet
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Basescan API key ──────────────────────────────────────────────────────────
# Get yours at https://basescan.org/myapikey (free account)
# Used to verify contracts after deploy.
BASESCAN_API_KEY=your_basescan_api_key_here

# ── Protocol addresses ────────────────────────────────────────────────────────
# Admin wallet — controls protocol roles after deploy (can be a multisig)
ADMIN_ADDRESS=0xyour_admin_wallet_here

# Fee wallet — receives protocol fees
FEE_WALLET=0xyour_fee_wallet_here

# Buy and burn contract — receives CLAW fees for deflation
# Deploy this separately or set to feeWallet initially
BUY_AND_BURN_ADDRESS=0xyour_buy_and_burn_address_here

# ── Token addresses (Base Mainnet — already deployed) ─────────────────────────
# USDC on Base
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# $CLAW token — deploy first, then paste address here
CLAW_ADDRESS=0x

# $CLAWX token — deploy first, then paste address here
CLAWX_ADDRESS=0x

# ── Gas reporting (optional) ──────────────────────────────────────────────────
# Set to "true" to generate a gas report after running tests
REPORT_GAS=false
