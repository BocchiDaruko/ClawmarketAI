{
  "name": "clawmarketai-backend",
  "version": "1.0.0",
  "description": "ClawmarketAI REST API — Node.js + Express + viem on Base",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start":     "node src/index.js",
    "dev":       "nodemon src/index.js",
    "test":      "node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "db:migrate":"node src/db/migrate.js",
    "lint":      "eslint src/"
  },
  "dependencies": {
    "express":          "^4.19.2",
    "viem":             "^2.17.0",
    "pg":               "^8.12.0",
    "ioredis":          "^5.3.2",
    "zod":              "^3.23.8",
    "winston":          "^3.13.0",
    "express-rate-limit":"^7.3.1",
    "helmet":           "^7.1.0",
    "cors":             "^2.8.5",
    "dotenv":           "^16.4.5",
    "ws":               "^8.18.0",
    "uuid":             "^10.0.0",
    "jsonwebtoken":     "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "jest":    "^29.7.0",
    "supertest":"^7.0.0"
  }
}
