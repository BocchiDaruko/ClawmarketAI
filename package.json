{
  "name": "clawmarketai",
  "version": "0.1.0",
  "description": "A self-operating decentralized marketplace powered by autonomous AI agents",
  "scripts": {
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy": "hardhat run scripts/deploy.js",
    "agent:deploy": "node scripts/deployAgent.js",
    "dashboard:start": "cd dashboard && npm run dev",
    "test": "hardhat test && pytest tests/",
    "lint": "eslint . && solhint contracts/**/*.sol"
  },
  "keywords": [
    "autonomous-agents",
    "ai",
    "blockchain",
    "decentralized-marketplace",
    "smart-wallets",
    "web3",
    "defi"
  ],
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.0",
    "solhint": "^4.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "viem": "^2.0.0",
    "ethers": "^6.0.0"
  }
}
